# Base URL of the TAKYfood backend API (no trailing slash).
# Copy this file to `.env.local` and fill in the real value.
VITE_API_BASE_URL=https://taiky-api-2026.vercel.app

# Public site origin (no trailing slash). Used server-side to build canonical
# og:url values in the prerender (scripts/prerender.mjs) and the SSR meta
# function (api/ssr.js). Set this in the Vercel project env too.
SITE_URL=https://takyfood.com.vn
